{
  "$schema": "https://raw.githubusercontent.com/googleapis/release-please/main/schemas/config.json",
  "packages": {
    "packages/sdk": {
      "release-type": "node",
      "package-name": "@ambosstech/lightning-mpp-sdk",
      "component": "sdk"
    },
    "packages/adapter-lnd": {
      "release-type": "node",
      "package-name": "@ambosstech/lightning-mpp-adapter-lnd",
      "component": "adapter-lnd"
    },
    "packages/adapter-mock": {
      "release-type": "node",
      "package-name": "@ambosstech/lightning-mpp-adapter-mock",
      "component": "adapter-mock"
    },
    "packages/adapter-nwc": {
      "release-type": "node",
      "package-name": "@ambosstech/lightning-mpp-adapter-nwc",
      "component": "adapter-nwc"
    }
  },
  "separate-pull-requests": false,
  "plugins": [
    {
      "type": "linked-versions",
      "groupName": "lightning-mpp",
      "components": ["sdk", "adapter-lnd", "adapter-mock", "adapter-nwc"]
    }
  ]
}

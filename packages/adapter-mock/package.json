  },
  "dependencies": {
    "@ambosstech/lightning-mpp-sdk": "workspace:*"
  },
  "devDependencies": {
    "@types/node": "^25.5.0",
    "tsup": "^8.3.0",
    "typescript": "~5.7.0",
    "vitest": "^2.1.0"
  }
}

{
  "name": "@ambosstech/lightning-mpp-adapter-lnd",
  "version": "0.1.2",
  "repository": {
    "type": "git",
    "url": "https://github.com/AmbossTech/lightning-mpp-sdk.git",
    "directory": "packages/adapter-lnd"
  },
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist",
    "proto",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsup",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@ambosstech/lightning-mpp-sdk": "workspace:*",
    "@grpc/grpc-js": "^1.12.0",
    "@grpc/proto-loader": "^0.7.13"
  },
  "devDependencies": {
    "tsup": "^8.3.0",
    "typescript": "~5.7.0",
    "vitest": "^2.1.0"
  }
}
